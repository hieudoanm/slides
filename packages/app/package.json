{
	"name": "@pitch/app",
	"version": "0.0.1",
	"private": true,
	"description": "Pitch Deck Generator",
	"keywords": [
		"pitch"
	],
	"homepage": "https://hieudoanm.github.io/pitch",
	"bugs": {
		"url": "https://github.com/hieudoanm/pitch/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+ssh://git@github.com/hieudoanm/pitch.git"
	},
	"license": "GPL-3.0",
	"author": "hieudoanm <hieumdoan@gmail.com> (https://hieudoanm.github.io)",
	"packageManager": "pnpm@10.29.2",
	"scripts": {
		"predev": "rimraf .next && kill-port 3000",
		"dev": "next dev --turbopack",
		"prebuild": "rimraf .next ../../docs",
		"build": "next build --turbopack",
		"postbuild": "touch ../../docs/.nojekyll",
		"build:tauri": "tauri build",
		"build:android": "rimraf mobile/android && cap add android",
		"build:ios": "rimraf mobile/ios && cap add ios",
		"build:mobile": "pnpm run build:android && pnpm run build:ios",
		"prestart": "kill-port 3000",
		"start": "next start",
		"lint": "eslint",
		"format": "prettier --cache --write .",
		"test": "jest"
	},
	"dependencies": {
		"@capacitor/android": "8.1.0",
		"@capacitor/core": "8.1.0",
		"@capacitor/ios": "8.1.0",
		"@codemirror/lang-yaml": "6.1.2",
		"@uiw/react-codemirror": "4.25.4",
		"html2canvas": "1.4.1",
		"jspdf": "4.1.0",
		"next": "16.1.6",
		"react": "19.2.4",
		"react-dom": "19.2.4",
		"yaml": "2.8.2"
	},
	"devDependencies": {
		"@capacitor/cli": "8.1.0",
		"@eslint/eslintrc": "3.3.3",
		"@tailwindcss/postcss": "4.1.18",
		"@tauri-apps/cli": "2.10.0",
		"@testing-library/jest-dom": "6.9.1",
		"@testing-library/react": "16.3.2",
		"@types/jest": "30.0.0",
		"@types/node": "25.2.3",
		"@types/react": "19.2.14",
		"@types/react-dom": "19.2.3",
		"daisyui": "5.5.18",
		"eslint": "10.0.0",
		"eslint-config-next": "16.1.6",
		"husky": "9.1.7",
		"jest": "30.2.0",
		"jest-environment-jsdom": "30.2.0",
		"kill-port": "2.0.1",
		"prettier": "3.8.1",
		"prettier-plugin-tailwindcss": "0.7.2",
		"rimraf": "6.1.2",
		"tailwindcss": "4.1.18",
		"ts-jest": "29.4.6",
		"ts-node": "10.9.2",
		"typescript": "5.9.3"
	}
}
