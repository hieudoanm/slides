{
  "name": "@slides/app",
  "version": "0.0.1",
  "private": true,
  "description": "Pitch Deck Generator",
  "keywords": [
    "pitch",
    "deck"
  ],
  "homepage": "https://hieudoanm.github.io/pitch.deck",
  "bugs": {
    "url": "https://github.com/hieudoanm/pitch.deck/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/hieudoanm/pitch.deck.git"
  },
  "license": "GPL-3.0",
  "author": "hieudoanm <hieumdoan@gmail.com> (https://hieudoanm.github.io)",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": "25.8.1"
  },
  "scripts": {
    "lint": "eslint . --fix",
    "format": "prettier --cache --write .",
    "predev": "rimraf .next && kill-port 3000",
    "dev": "next dev --turbopack",
    "pretest": "jest --clearCache",
    "test": "jest",
    "prebuild": "rimraf .next ../../docs",
    "build": "next build --turbopack",
    "postbuild": "touch ../../docs/.nojekyll",
    "build:tauri": "tauri build",
    "build:android": "rimraf mobile/android && cap add android",
    "build:ios": "rimraf mobile/ios && cap add ios",
    "build:mobile": "pnpm run build:android && pnpm run build:ios",
    "prestart": "kill-port 3000",
    "start": "next start"
  },
  "dependencies": {
    "@capacitor/android": "8.2.0",
    "@capacitor/core": "8.2.0",
    "@capacitor/ios": "8.2.0",
    "@codemirror/lang-yaml": "6.1.3",
    "@uiw/react-codemirror": "4.25.8",
    "html2canvas": "1.4.1",
    "jspdf": "4.2.1",
    "next": "16.2.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "yaml": "2.8.3"
  },
  "devDependencies": {
    "@capacitor/cli": "8.2.0",
    "@eslint/eslintrc": "3.3.5",
    "@tailwindcss/postcss": "4.2.2",
    "@tauri-apps/cli": "2.10.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/jest": "30.0.0",
    "@types/node": "25.5.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "babel-plugin-react-compiler": "1.0.0",
    "daisyui": "5.5.19",
    "eslint": "10.1.0",
    "eslint-config-next": "16.2.1",
    "jest": "30.3.0",
    "jest-environment-jsdom": "30.3.0",
    "kill-port": "2.0.1",
    "prettier": "3.8.1",
    "prettier-plugin-tailwindcss": "0.7.2",
    "rimraf": "6.1.3",
    "tailwindcss": "4.2.2",
    "ts-jest": "29.4.6",
    "ts-node": "10.9.2",
    "typescript": "6.0.2"
  }
}
